# Supabase connection — when BOTH are set, the server reads from Postgres.
# When absent, it falls back to the local JSON files under data/maps/.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Only needed by `npm run seed` (writes bypass RLS with the service role key).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override where the local fallback / seed script reads map JSON from.
# MIGRATION_DATA_DIR=
